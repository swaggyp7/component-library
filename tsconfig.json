{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", ".storybook"],
  "exclude": [
    "dist",
    "node_modules",
    "storybook-static",
    "src/**/*.stories.*",
    "src/**/*.test.*",
    "src/setupTests.ts"
  ]
}
